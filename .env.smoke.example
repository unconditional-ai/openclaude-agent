# Copy to .env.smoke (gitignored) and use for local dev + smoke tests.
# Points the agent and smoke tests at a SEPARATE TEST BASE in NocoDB —
# never touches production data. Same NocoDB instance, different base.
#
# Required for smoke-tests.sh to pass safety check.

NC_TOKEN=nc_pat_yourtokenhere

# === Test base + tables (Operations Test in NocoDB) ===
NOCODB_URL=https://openclaude-nocodb.onrender.com
PEOPLE_TABLE_ID=mxvlo7p0w9ku2lp
COHORTS_TABLE_ID=muvlnnh30w4cmmj
TOUCHPOINTS_TABLE_ID=m9p0uz89fvarx9n
AGENT_ACTIONS_TABLE_ID=mivsfgzgynmey78
COHORTS_LINK_COLUMN_ID=c8ovdznbwqbd0dq
TOUCHPOINTS_PERSON_LINK_COLUMN_ID=cnd7428fr0pkfjx

# === Agent service env (so npm start uses test base) ===
ANTHROPIC_API_KEY=sk-ant-yourkeyhere
NOCODB_TOKEN=$NC_TOKEN
SLACK_BOT_TOKEN=xoxb-... (your bot token, optional for smoke tests)
CLICKUP_TOKEN=pk_... (optional)
CLICKUP_DEFAULT_LIST_ID=901613217899
AGENT_MODEL=claude-sonnet-4-6

# Smoke tests default to localhost. Override only if testing a different env.
# AGENT_URL=http://localhost:10000

# Safety flag — smoke-tests.sh refuses to run unless this is "test"
OPENCLAUDE_ENV=test
